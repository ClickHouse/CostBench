# =============================================================================
# Config template for the Snowflake quotes benchmark.
# Copy to `.sfenv` ON THE BOX and fill in real values, then `source .sfenv`.
# The filled-in file is gitignored — NEVER commit real credentials.
# See NEXT_BENCHMARK_RUNBOOK.md for how each benchmark (T0/T1/T2) uses these.
# =============================================================================

# --- Snowflake account (Paris box = original account; London box = new account) ---
export SF_ACCOUNT=ORG-ACCOUNT                       # Snowflake account identifier
export SF_USER=YOUR_USER
export SF_KEY=/home/ubuntu/bench/keys/rsa_key.p8    # PKCS8 private key path (gitignored)
export SF_SCHEMA=STOCKHOUSE                         # STOCKHOUSE (T0/T1) | STREAMING (T2)

# --- Warehouses ---
export SF_WAREHOUSE=BENCH2COST_SMALL_GEN2           # the MEASURED read warehouse
export SF_TRACK_WAREHOUSE=BENCH_TRACK               # separate wh for COUNT(*) / timing lookups

# --- Runner table targets (override per benchmark) ---
#   T0:  SF_RAW_TABLE=QUOTES     SF_MV_TABLE=QUOTES_DAILY
#   T1:  SF_RAW_TABLE=QUOTES_IT  SF_MV_TABLE=QUOTES_DAILY_IT
#   T2:  SF_RAW_TABLE=QUOTES_IT  SF_MV_TABLE=QUOTES_DAILY_IMV   (with SF_SCHEMA=STREAMING)
export SF_RAW_TABLE=QUOTES
export SF_MV_TABLE=QUOTES_DAILY

# --- T1 interactive-table refresh warehouses (used by ops/setup_interactive.sh) ---
export AGG_WH=BENCH2COST_GEN2_MEDIUM   AGG_SIZE=MEDIUM   AGG_LAG='1 minute'    # QUOTES_DAILY_IT
export RAW_WH=BENCH2COST_GEN2_XSMALL   RAW_SIZE=XSMALL   RAW_LAG='10 minutes'  # QUOTES_IT

# --- AWS (only to download the dataset from S3; temporary session creds) ---
export AWS_ACCESS_KEY_ID=
export AWS_SECRET_ACCESS_KEY=
export AWS_SESSION_TOKEN=
export AWS_DEFAULT_REGION=us-east-2

# --- ClickHouse baseline (run from any host with clickhouse-client) ---
export FQDN=xxxx.us-east-2.aws.clickhouse-staging.com
export PASSWORD=
